# app/ is GENERATED by build.sh but MUST be committed — Vibe deploys via git push
# and its Docker build copies committed files (it does not run build.sh). So do not
# ignore app/ itself; only ignore caches and local runtime output.
__pycache__/
*.pyc
app/**/__pycache__/
app/output/
app/.runtime/
app/input_documents/
